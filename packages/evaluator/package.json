{
  "name": "@vestlang/evaluator",
  "version": "0.1.1",
  "description": "The spec-to-canonical compiler: resolves vestlang programs against runtime into the canonical interchange. Proposed reference implementation.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json",
    "test": "vitest",
    "test:mutation": "stryker run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vestlang/core": "workspace:*",
    "@vestlang/dsl": "workspace:*",
    "@vestlang/normalizer": "workspace:*",
    "@vestlang/primitives": "workspace:*",
    "@vestlang/render": "workspace:*",
    "@vestlang/types": "workspace:*",
    "@vestlang/utils": "workspace:*",
    "@vestlang/walk": "workspace:*"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
