{
  "name": "@vestlang/vestlang",
  "version": "0.6.0",
  "type": "module",
  "license": "MIT",
  "description": "A domain-specific language for modeling vesting schedules",
  "keywords": [
    "vestlang",
    "vesting",
    "equity",
    "options",
    "schedule",
    "dsl",
    "stock"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattCantor/vestlang.git",
    "directory": "packages/vestlang"
  },
  "bugs": {
    "url": "https://github.com/MattCantor/vestlang/issues"
  },
  "homepage": "https://github.com/MattCantor/vestlang#readme",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vestlang/core": "workspace:*",
    "zod": "^4.0"
  },
  "devDependencies": {
    "@vestlang/dsl": "workspace:*",
    "@vestlang/evaluator": "workspace:*",
    "@vestlang/inferrer": "workspace:*",
    "@vestlang/linter": "workspace:*",
    "@vestlang/normalizer": "workspace:*",
    "@vestlang/pipeline": "workspace:*",
    "@vestlang/recover": "workspace:*",
    "@vestlang/render": "workspace:*",
    "@vestlang/types": "workspace:*",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.8",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
