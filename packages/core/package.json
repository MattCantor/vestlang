{
  "name": "@vestlang/core",
  "version": "0.1.1",
  "description": "Open Cap Table Coalition aligned interchange engine for vesting schedules.",
  "license": "MIT",
  "keywords": [
    "vestlang",
    "vesting",
    "equity",
    "canonical",
    "interchange",
    "compiler",
    "ocf"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattCantor/vestlang.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/MattCantor/vestlang/issues"
  },
  "homepage": "https://github.com/MattCantor/vestlang#readme",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:mutation": "stryker run",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vestlang/primitives": "workspace:*",
    "@vestlang/types": "workspace:*",
    "@vestlang/utils": "workspace:*",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.8",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
