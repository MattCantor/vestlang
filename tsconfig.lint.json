{
  // Whole-repo program for type-aware ESLint and the standalone `typecheck`
  // script. Unlike the per-package build tsconfigs (which `include: ["src"]`),
  // this also pulls in test files, so type errors in tests are caught too.
  // Emits nothing; cross-package imports resolve through the built `dist`
  // outputs, so run after a build (CI builds first; turbo's test task already
  // depends on ^build).
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    // The `node`-run guard scripts import their shared lib by its real `.mts`
    // path — Node's type stripping doesn't rewrite `.mjs` to `.mts`, unlike the
    // test/vitest imports. Emit-free, so the extension in the specifier is fine.
    "allowImportingTsExtensions": true,
  },
  "include": ["packages", "apps/cli", "apps/mcp-server", "tests", "scripts"],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "packages/dsl/src/generated",
    "apps/docs",
  ],
}
