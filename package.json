{
  "name": "vestlang",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattCantor/vestlang.git"
  },
  "bugs": {
    "url": "https://github.com/MattCantor/vestlang/issues"
  },
  "homepage": "https://github.com/MattCantor/vestlang#readme",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@vestlang/prettier-plugin-vestlang": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.5.2",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-turbo": "^2.9.6",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "knip": "^6.15.0",
    "prettier": "^3.6.2",
    "prettier-plugin-pegjs": "^2.0.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.2.4"
  }
}
