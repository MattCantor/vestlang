{
  "name": "@vestlang/mcp-server",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Model Context Protocol server for vestlang — parse, compile, evaluate, lint and infer vesting schedules, plus the grammar and spec as MCP resources.",
  "keywords": [
    "vestlang",
    "vesting",
    "equity",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "dsl"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattCantor/vestlang.git",
    "directory": "apps/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/MattCantor/vestlang/issues"
  },
  "homepage": "https://github.com/MattCantor/vestlang#readme",
  "engines": {
    "node": ">=18.2"
  },
  "bin": {
    "vestlang-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "resources",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "predev": "tsx scripts/copy-resources.ts",
    "dev": "tsx src/index.ts",
    "predev:http": "tsx scripts/copy-resources.ts",
    "dev:http": "tsx src/index.ts --http",
    "prebuild": "tsx scripts/copy-resources.ts",
    "build": "tsdown",
    "start:http": "node dist/index.js --http",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "clean": "rimraf dist resources"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@vestlang/core": "workspace:*",
    "@vestlang/evaluator": "workspace:*",
    "@vestlang/inferrer": "workspace:*",
    "@vestlang/linter": "workspace:*",
    "@vestlang/pipeline": "workspace:*",
    "@vestlang/primitives": "workspace:*",
    "@vestlang/render": "workspace:*",
    "@vestlang/types": "workspace:*",
    "@vestlang/utils": "workspace:*",
    "@vestlang/vestlang": "workspace:*",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.8",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
