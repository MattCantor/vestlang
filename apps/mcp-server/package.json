    "zod": "^4.0"
  },
  "devDependencies": {
    "@vestlang/core": "workspace:*",
    "@vestlang/vestlang": "workspace:*",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
